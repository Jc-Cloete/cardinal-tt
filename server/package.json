{
  "name": "cardinal-tt-server",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "bun --watch index.ts",
    "start": "bun run index.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "cd .. && biome check server --error-on-warnings",
    "lint:fix": "cd .. && biome check server --write --unsafe --error-on-warnings",
    "test": "bun test src/__tests__/*.test.ts",
    "test:api": "bun test src/__tests__/api-contract.spec.ts"
  },
  "dependencies": {
    "cardinal-observability": "workspace:*",
    "cardinal-store": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "bun-types": "^1.3.0",
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3"
  }
}
