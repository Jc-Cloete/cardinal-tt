{
  "name": "cardinal-activity",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "bun --watch index.ts agent run",
    "start": "bun run index.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "cd .. && biome check cardinal-activity --error-on-warnings",
    "lint:fix": "cd .. && biome check cardinal-activity --write --unsafe --error-on-warnings",
    "test": "bun test"
  },
  "dependencies": {
    "cardinal-observability": "workspace:*",
    "cardinal-store": "workspace:*",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "bun-types": "^1.3.0",
    "typescript": "^5.6.3"
  }
}
